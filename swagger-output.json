{
  "swagger": "2.0",
  "info": {
    "title": "Line Map Studio API",
    "description": "選單地圖工具 API 文件",
    "version": "1.0.0"
  },
  "host": "linemap-studio-backend.onrender.com",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "請加上 Bearer 前綴，例如：Bearer <TOKEN>"
    }
  },
  "paths": {
    "/users/login/line": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Line Login 登入",
        "description": "前端傳入 Line ID Token，後端驗證後核發系統 JWT",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Line 驗證資訊",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id_token": {
                  "type": "string",
                  "example": "ID Token"
                }
              },
              "required": [
                "id_token"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "登入成功",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "success"
                },
                "message": {
                  "type": "string",
                  "example": "登入成功"
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1..."
                    },
                    "name": {
                      "type": "string",
                      "example": "小明"
                    },
                    "photo": {
                      "type": "string",
                      "example": "https://example.com/photo.jpg"
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "400": {
            "description": "請求格式錯誤",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "false"
                },
                "message": {
                  "type": "string",
                  "example": "缺少 Line 驗證碼 (ID Token)"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "LINE 驗證失敗",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "false"
                },
                "message": {
                  "type": "string",
                  "example": "Line 身分驗證失敗，請重新登入"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          }
        }
      }
    },
    "/users/getUser": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "取得使用者資料",
        "description": "取得目前登入使用者的資料",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "成功取得資料",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "success"
                },
                "message": {
                  "type": "string",
                  "example": "成功取得使用者資料"
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string",
                      "example": "6641ab..."
                    },
                    "displayName": {
                      "type": "string",
                      "example": "小明"
                    },
                    "pictureUrl": {
                      "type": "string",
                      "example": "https://example.com/photo.jpg"
                    },
                    "lineUserId": {
                      "type": "string",
                      "example": "U123456..."
                    },
                    "createdAt": {
                      "type": "string",
                      "example": "2026-05-13T09:00:00.000Z"
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "身分驗證失敗",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "false"
                },
                "message": {
                  "type": "string",
                  "example": "您尚未登入！"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/users/check-friendship": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "檢查頻道好友狀態",
        "description": "確認使用者是否已加入官方帳號好友且未封鎖",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "成功取得好友狀態(包含是好友與非好友的情境。message 會不同，但 schema 結構相同)",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "success"
                },
                "message": {
                  "type": "string",
                  "example": "使用者已加入好友"
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "isFriend": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "身分驗證失敗",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "false"
                },
                "message": {
                  "type": "string",
                  "example": "您尚未登入！"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "500": {
            "description": "伺服器內部錯誤 (LINE API 呼叫失敗)",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "false"
                },
                "message": {
                  "type": "string",
                  "example": "檢查好友狀態失敗"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    }
  }
}